```gitignore
# Dependencies
node_modules/

# Environment variables (IMPORTANT - never push secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/

# Build folders
dist/
build/

# Cache
.cache/
.parcel-cache/
.vite/

# Uploads / user generated files
uploads/
temp/
tmp/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# Optional lock files (keep ONE depending on package manager)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
```
